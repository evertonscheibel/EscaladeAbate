
/* Checkbox List for Technicians */
.checkbox-list-container {
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px;
    max-height: 150px;
    overflow-y: auto;
    background: #f8fafc;
}

.checkbox-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
}

.checkbox-item:hover {
    background: #e2e8f0;
}

.checkbox-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: #667eea;
}

.checkbox-item span {
    font-size: 14px;
    color: #1e293b;
    font-weight: 500;
}
